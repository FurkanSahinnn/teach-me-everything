{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Teach Me Everything",
  "version": "1.0.0",
  "identifier": "com.tme.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:export"
  },
  "app": {
    "windows": [
      {
        "title": "Teach Me Everything",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Open with Teach Me Everything",
        "mimeType": "text/markdown",
        "role": "Viewer"
      }
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true,
    "resources": ["binaries/piper-*/**/*"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/FurkanSahinnn/teach-me-everything/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3MzA1NjY2QkYxN0VEMDAKUldRQTdSZS9abFl3aCthSHRPTzZpUzg5SUpDUVhqZTFaMjJJSFRDeTdxT2ZPSE4rM2VlNEw0b0oK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
