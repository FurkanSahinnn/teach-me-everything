{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main window. Grants the JS layer access to (1) the core plugin set + log plugin and (2) outbound HTTP to the curated list of LLM / research / TTS / search provider hosts that Phase 7.2 client-side calls require.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default",
    "dialog:default",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "notification:default",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "updater:allow-download-and-install",
    "process:default",
    "process:allow-restart",
    "opener:default",
    "allow-tts-piper-check-readiness",
    "allow-tts-piper-synthesize",
    "allow-tts-list-installed-voices",
    "allow-tts-install-voice",
    "allow-tts-delete-voice",
    "allow-sysinfo-probe",
    "allow-sysinfo-gpu",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" }
      ]
    },
    "allow-keychain",
    "fs:default",
    "fs:allow-mkdir",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.openai.com/*" },
        { "url": "https://api.x.ai/*" },
        { "url": "https://api.mistral.ai/*" },
        { "url": "https://api.perplexity.ai/*" },
        { "url": "https://api.deepseek.com/*" },
        { "url": "https://api.groq.com/*" },
        { "url": "https://api.together.xyz/*" },
        { "url": "https://api.fireworks.ai/*" },
        { "url": "https://generativelanguage.googleapis.com/*" },
        { "url": "https://openrouter.ai/*" },
        { "url": "https://open.bigmodel.cn/*" },
        { "url": "https://api.z.ai/*" },
        { "url": "https://api.voyageai.com/*" },
        { "url": "https://api.cohere.com/*" },
        { "url": "https://api.jina.ai/*" },
        { "url": "https://r.jina.ai/*" },
        { "url": "https://router.huggingface.co/*" },
        { "url": "https://huggingface.co/*" },
        { "url": "https://api.firecrawl.dev/*" },
        { "url": "https://api.exa.ai/*" },
        { "url": "https://api.tavily.com/*" },
        { "url": "https://api.search.brave.com/*" },
        { "url": "https://api.diffbot.com/*" },
        { "url": "https://api.brightdata.com/*" },
        { "url": "https://www.googleapis.com/*" },
        { "url": "https://youtube.googleapis.com/*" },
        { "url": "https://*.openai.azure.com/*" },
        { "url": "http://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" }
      ]
    }
  ]
}
